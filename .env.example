# Discord / Bot credentials
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_application_client_id_here

# Database
# connection_limit tunes Prisma's own pool for a single-process bot — omit it
# and Prisma defaults to num_cpus*2+1, which over-provisions on small hosts.
# connect_timeout and pool_timeout are raised because serverless Postgres (e.g.
# Neon) auto-suspends on idle — the first burst of queries after a suspend has
# to wait for a cold-start "wake" that can take several seconds per connection,
# and every queued query needs to survive the whole pool warming back up, not
# just its own connection attempt. Prisma's defaults (connect_timeout=5,
# pool_timeout=10) are tuned for an always-warm DB and are too tight here.
DATABASE_URL=postgresql://devos:devos_password@localhost:5432/devos?connection_limit=10&connect_timeout=20&pool_timeout=30

# GitHub — optional at boot, but required in practice for /link github to work.
# The poller runs every 2 minutes; unauthenticated GitHub REST is capped at 60
# requests/hour, which that interval exhausts almost immediately, and the GraphQL
# API used for private-activity detection rejects unauthenticated requests
# outright. The bot starts fine without it and logs a warning — but leave it
# unset only if you don't intend to use the GitHub integration at all.
# A classic PAT with no scopes is enough for public data.
GITHUB_TOKEN=your_github_personal_access_token_here

# Branding: optional override for the embed footer icon.
#
# You almost certainly do NOT need this. By default the bot uses its own
# avatar, which Discord already hosts on its CDN — so the footer icon works
# with no configuration as soon as the bot has a profile picture. Set that
# picture by uploading src/assets/nerdcult-icon-1024.png via the Discord
# Developer Portal (Bot tab), or with AUTO_SET_AVATAR=true below.
#
# Only set this to point the footer at a DIFFERENT image than the avatar. It
# must be a public HTTPS URL Discord can fetch anonymously — note that a
# raw.githubusercontent.com link only works if the repo is PUBLIC.
# Leaving it blank (BOT_ICON_URL=) is treated as unset, not as an error.
# BOT_ICON_URL=https://example.com/some-other-icon.png

# Branding: set to "true" to have the bot set its own avatar from
# src/assets/nerdcult-icon-512.png once on startup. Off by default.
# NOTE: Discord rate-limits avatar changes to roughly a couple per hour, so
# this runs once and is never retried — leaving it "true" across many dev
# restarts will start failing. The simpler, recommended path is to upload
# src/assets/nerdcult-icon-1024.png manually via the Discord Developer Portal
# (Bot tab). This flag is just a convenience for automating that.
# AUTO_SET_AVATAR=true

# ── Health endpoint ───────────────────────────────────────────────────────────
# Port for GET /health (src/server/healthServer.ts). Optional — defaults to 8000.
# Hosting platforms inject this themselves (Koyeb sets PORT=8000), so leave it
# unset in production. Set it locally only if 8000 is already taken.
# PORT=8000
