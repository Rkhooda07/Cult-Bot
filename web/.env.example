# OAuth2 invite URL for the bot. Copy this file to .env.local and fill it in.
# Unset, the "Add to Discord" button links to "#" and warns in dev.
NEXT_PUBLIC_DISCORD_INVITE_URL=

# GitHub repo URL shown in the footer. Unset, the link points to "#".
NEXT_PUBLIC_GITHUB_URL=

# Only needed once a custom domain is attached — used as the absolute base for
# Open Graph image URLs. On Vercel this is inferred automatically when unset.
NEXT_PUBLIC_SITE_URL=
