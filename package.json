  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@discordjs/builders": "^1.10.0",
    "@prisma/client": "^6.0.0",
    "chrono-node": "^2.7.7",
    "discord.js": "^14.17.0",
    "dotenv": "^16.4.7",
    "luxon": "^3.5.0",
    "node-cron": "^3.0.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
